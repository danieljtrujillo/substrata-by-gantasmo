{
  "name": "substrata",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:full": "npx wrangler pages dev --d1=DB -- npx vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "npx wrangler pages dev dist --d1=DB",
    "db:migrate": "npx wrangler d1 execute substrata-db --remote --file=schema.sql",
    "db:migrate:local": "npx wrangler d1 execute substrata-db --local --file=schema.sql",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "konva": "^10.2.5",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.14.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.7",
    "react-konva": "^19.2.3",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "three-csg-ts": "^3.2.0",
    "tw-animate-css": "^1.4.0",
    "use-image": "^1.1.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
