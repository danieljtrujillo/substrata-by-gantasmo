rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() {
      // Mandating verified email for security
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Assistants ---
    
    /**
     * Validates User Profile Data
     */
    function isValidProfile(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) &&
             data.keys().size() <= 7 && // userId, email, createdAt, displayName, photoURL + small margin
             data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048));
    }

    /**
     * Validates Laser Project Data
     */
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 10 &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.userId == request.auth.uid &&
             // Ensure images aren't absurdly large (protecting DB costs)
             (data.originalImage == null || (data.originalImage is string && data.originalImage.size() <= 1048576)) &&
             (data.processedImage == null || (data.processedImage is string && data.processedImage.size() <= 1048576));
    }

    // --- Resources ---

    match /users/{userId} {
      
      // User Profile Security
      match /profile {
        // Only the owner can fetch their own profile
        allow get: if isOwner(userId);
        
        // Creation requires mandatory valid structure and server timestamp
        allow create: if isOwner(userId) && isValidProfile(incoming()) && incoming().createdAt == request.time;
        
        // Profile updates: Only non-immutable fields can change
        allow update: if isOwner(userId) && isValidProfile(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
      }

      // Laser Projects Security
      match /projects/{projectId} {
        // Hardened List Query: User must be owner
        allow list: if isOwner(userId);
        
        // Targeted access check
        allow get: if isOwner(userId);
        
        // Creation with valid ID and strict schema
        allow create: if isOwner(userId) && isValidId(projectId) && isValidProject(incoming()) && 
                      incoming().createdAt == request.time && incoming().updatedAt == request.time;
        
        // Detailed Update Logic per Pillar 4
        allow update: if isOwner(userId) && isValidId(projectId) && isValidProject(incoming()) &&
                      incoming().id == existing().id &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      (
                        // Action: Rename or update settings
                        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'originalImage', 'processedImage', 'laserSettings', 'procOptions', 'updatedAt'])
                      );
                      
        // Deletion
        allow delete: if isOwner(userId);
      }
    }
  }
}
